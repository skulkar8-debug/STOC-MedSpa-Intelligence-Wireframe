<script>
/* ═══════════════════════════════════════════
   DATA & RENDER FUNCTIONS
═══════════════════════════════════════════ */

// Nav active highlight on scroll
const navItems = document.querySelectorAll('.nav-item');
const sections = document.querySelectorAll('.slide');

const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      navItems.forEach(n => n.classList.remove('active'));
      const id = entry.target.id;
      const match = document.querySelector(`.nav-item[href="#${id}"]`);
      if (match) match.classList.add('active');
    }
  });
}, { threshold: 0.3 });
sections.forEach(s => observer.observe(s));

// ── Horizontal bar renderer ────────────────
function renderHbars(containerId, rows, colorFn) {
  const el = document.getElementById(containerId);
  if (!el) return;
  el.innerHTML = rows.map(([label, pct, color]) => `
    <div class="hbar-wrap" style="margin-bottom:10px">
      <div class="hbar-label">${label}</div>
      <div class="hbar-track"><div class="hbar-fill" style="width:${pct}%;background:${color}"></div></div>
      <div class="hbar-pct">${pct}%</div>
    </div>`).join('');
}

// ── SLIDE 2: Top 10 States ─────────────────
const top10 = [
  ["California","CA",680,"★★★"],["Texas","TX",520,"★★★"],["Florida","FL",490,"★★★"],
  ["New York","NY",310,"★★☆"],["Georgia","GA",240,"★★☆"],["Illinois","IL",210,"★★☆"],
  ["Arizona","AZ",195,"★★☆"],["Colorado","CO",170,"★★☆"],["Washington","WA",155,"★☆☆"],["Nevada","NV",140,"★☆☆"]
];
document.getElementById('top10States').innerHTML = top10.map(([state,abbr,count,stars],i) => `
  <tr>
    <td class="td-muted td-center" style="font-size:11px">${i+1}</td>
    <td class="td-bold">${state}</td>
    <td class="td-center td-blue" style="font-weight:700">${count.toLocaleString()}</td>
    <td class="td-center" style="font-size:14px;letter-spacing:-1px;color:var(--blue)">${stars}</td>
  </tr>`).join('');

// ── SLIDE 3: Rating bars ───────────────────
renderHbars('ratingBars', [
  ["5.0 ★★★★★",22,"var(--green)"],
  ["4.5–4.9 ★★★★",38,"var(--blue)"],
  ["4.0–4.4 ★★★",24,"var(--indigo)"],
  ["3.5–3.9 ★★",10,"var(--muted)"],
  ["Below 3.5 ★",6,"var(--red)"]
]);

renderHbars('reviewBars', [
  ["0–10 reviews",28,"var(--muted)"],
  ["11–50 reviews",34,"var(--indigo)"],
  ["51–100 reviews",18,"var(--blue)"],
  ["101–500 reviews",14,"var(--navy)"],
  ["500+ reviews",6,"var(--green)"]
]);

// ── SLIDE 5: Services bars ─────────────────
renderHbars('servicesBars', [
  ["Botox / Neurotoxin",88,"var(--blue)"],
  ["Dermal Fillers",82,"var(--blue)"],
  ["Laser / IPL Treatment",64,"var(--indigo)"],
  ["Body Contouring",51,"var(--indigo)"],
  ["Skin Tightening",48,"var(--light-blue)"],
  ["Chemical Peels",44,"var(--light-blue)"],
  ["IV Therapy",31,"var(--muted)"],
  ["Weight Loss (Semaglutide)",28,"var(--red)"]
]);

renderHbars('densityBars', [
  ["Very Low (0–20)",12,"var(--green)"],
  ["Low (21–40)",28,"var(--teal)"],
  ["Medium (41–60)",35,"var(--blue)"],
  ["High (61–80)",18,"var(--indigo)"],
  ["Very High (81–100)",7,"var(--red)"]
]);

// ── SLIDE 6: Staffing bars ─────────────────
renderHbars('staffingBars', [
  ["Medical Director on Staff",34,"var(--indigo)"],
  ["Registered Nurse(s)",52,"var(--blue)"],
  ["Licensed Aesthetician(s)",61,"var(--blue)"],
  ["Plastic Surgery Services",22,"var(--red)"],
  ["Dermatology Services",18,"var(--red)"]
]);

// ── SLIDE 7: PE heat rows ──────────────────
const peRegions = [
  ["Southeast","High",82,"pe-label-hot"],
  ["Texas / SW","High",74,"pe-label-hot"],
  ["West Coast","Medium",51,"pe-label-warm"],
  ["Northeast","Medium",48,"pe-label-warm"],
  ["Midwest","Low",28,"pe-label-cool"],
  ["Mountain / CO","Low",22,"pe-label-cool"],
  ["SE Rural","Minimal",8,"pe-label-min"]
];
document.getElementById('peHeatRows').innerHTML = peRegions.map(([region,label,pct,cls],i) => `
  <div class="pe-heat-row" style="${i%2===0?'background:var(--bg)':''}">
    <div class="pe-region">${region}</div>
    <div class="${cls}">${label}</div>
    <div style="display:flex;align-items:center;gap:8px">
      <div style="flex:1;height:6px;background:var(--border);border-radius:2px;overflow:hidden">
        <div style="height:100%;width:${pct}%;background:${pct>70?'var(--red)':pct>40?'var(--amber)':pct>15?'var(--teal)':'var(--green)'};border-radius:2px"></div>
      </div>
      <span style="font-size:11px;color:var(--muted);min-width:28px">${pct}%</span>
    </div>
  </div>`).join('');

// ── SLIDE 8: Validation bars ───────────────
renderHbars('validationBars', [
  ["90–100 (Fully Validated)",44,"var(--blue)"],
  ["70–89 (Mostly Complete)",26,"var(--indigo)"],
  ["50–69 (Partial)",18,"var(--light-blue)"],
  ["< 50 (Incomplete)",12,"var(--muted)"]
]);

renderHbars('emailStatusBars', [
  ["Email Sent",62,"var(--blue)"],
  ["Replied (Positive)",14,"var(--green)"],
  ["No Reply",48,"var(--muted)"]
]);

// ── SLIDE 10: By State Table ───────────────
const stateData = [
  ["AL",22,129,212,363,151,6.1,35.5,58.4],["AR",28,47,191,266,75,10.5,17.7,71.8],
  ["AZ",168,174,87,429,342,39.2,40.6,20.3],["CA",931,1786,567,3284,2717,28.3,54.4,17.3],
  ["CO",132,252,152,536,384,24.6,47.0,28.4],["CT",17,159,168,344,176,4.9,46.2,48.8],
  ["DE",11,43,39,93,54,11.8,46.2,41.9],["FL",233,738,616,1587,971,14.7,46.5,38.8],
  ["GA",256,198,176,630,454,40.6,31.4,27.9],["IA",18,77,177,272,95,6.6,28.3,65.1],
  ["ID",43,89,54,186,132,23.1,47.8,29.0],["IL",101,416,480,997,517,10.1,41.7,48.1],
  ["IN",60,164,246,470,224,12.8,34.9,52.3],["KS",23,53,234,310,76,7.4,17.1,75.5],
  ["KY",33,119,154,306,152,10.8,38.9,50.3],["LA",18,95,213,326,113,5.5,29.1,65.3],
  ["MA",117,191,131,439,308,26.7,43.5,29.8],["MD",89,203,148,440,292,20.2,46.1,33.6],
  ["MI",98,287,312,697,385,14.1,41.2,44.8],["MN",71,184,201,456,255,15.6,40.4,44.1],
  ["MO",84,192,268,544,276,15.4,35.3,49.3],["NC",189,312,248,749,501,25.2,41.7,33.1],
  ["NJ",142,381,298,821,523,17.3,46.4,36.3],["NV",97,183,148,428,280,22.7,42.8,34.6],
  ["NY",310,742,468,1520,1052,20.4,48.8,30.8],["OH",112,388,412,912,500,12.3,42.5,45.2],
  ["OR",87,164,142,393,251,22.1,41.7,36.1],["PA",148,421,398,967,569,15.3,43.5,41.2],
  ["SC",78,142,168,388,220,20.1,36.6,43.3],["TN",142,248,196,586,390,24.2,42.3,33.4],
  ["TX",520,1124,612,2256,1644,23.1,49.8,27.1],["UT",88,176,124,388,264,22.7,45.4,32.0],
  ["VA",132,284,218,634,416,20.8,44.8,34.4],["WA",155,312,244,711,467,21.8,43.9,34.3],
  ["WI",67,182,228,477,249,14.0,38.2,47.8],
];

function pctHClass(v) {
  return v >= 30 ? 'td-pct-hot' : v >= 18 ? 'td-pct-warm' : 'td-pct-cool';
}

function tierAccent(hp) {
  if (hp >= 25) return 'var(--blue)';
  if (hp >= 15) return 'var(--indigo)';
  return 'var(--light-blue)';
}

document.getElementById('stateTableBody').innerHTML = stateData.map(([st,h,m,l,t,a,hp,mp,lp],i) => `
  <tr>
    <td style="font-weight:700;font-size:12px;color:var(--navy);letter-spacing:0.08em;padding-left:16px;border-right:2px solid var(--border);position:relative">
      <span style="position:absolute;left:6px;top:50%;transform:translateY(-50%);width:3px;height:14px;border-radius:2px;background:${tierAccent(hp)}"></span>
      ${st}
    </td>
    <td class="td-center" style="color:var(--blue);font-weight:600">${h.toLocaleString()}</td>
    <td class="td-center" style="color:var(--indigo)">${m.toLocaleString()}</td>
    <td class="td-center" style="color:var(--muted)">${l.toLocaleString()}</td>
    <td class="td-center td-bold" style="border-right:2px solid rgba(56,59,110,0.2)">${t.toLocaleString()}</td>
    <td class="td-center" style="color:${a/t>0.3?'var(--teal)':'var(--slate)'};font-weight:${a/t>0.3?'700':'400'}">${a.toLocaleString()}</td>
    <td class="td-center">
      <div class="pct-cell" style="justify-content:center">
        <span class="pct-val ${pctHClass(hp)}">${hp.toFixed(1)}%</span>
        <div class="pct-mini-track"><div class="pct-mini-fill" style="width:${Math.min(hp*1.2,100)}%;background:${hp>=30?'var(--blue)':hp>=18?'var(--blue-dark)':'var(--border)'}"></div></div>
      </div>
    </td>
    <td class="td-center" style="color:var(--slate)">${mp.toFixed(1)}%</td>
    <td class="td-center" style="color:var(--muted)">${lp.toFixed(1)}%</td>
  </tr>`).join('');

</script>
</body>
</html>
