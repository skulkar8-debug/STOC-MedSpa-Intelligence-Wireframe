<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STOC Advisory - MedSpa Market Intelligence Report</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════
   STOC DESIGN SYSTEM - EXACT BRAND COLORS
═══════════════════════════════════════════════════════ */
:root {
  --blue:        #0F75BD;
  --indigo:      #383B6E;
  --navy:        #041E3F;
  --white:       #FFFFFF;
  --light-blue:  #BACAEC;

  /* Functional palette derived from brand */
  --navy-mid:    #0A2A50;
  --navy-90:     #071E3A;
  --blue-dark:   #0A5F9A;
  --blue-light:  #D6E8F7;
  --blue-xlt:    #EBF4FD;
  --indigo-lt:   #ECEDF6;
  --slate:       #4A5E7A;
  --muted:       #8299B8;
  --border:      #CDD8EA;
  --border-lt:   #E4EAFA;
  --bg:          #F2F6FB;
  --bg-alt:      #E8EFF8;

  /* Accent */
  --green:       #1A9A6C;
  --green-lt:    #E6F7F2;
  --amber:       #C47A0F;
  --amber-lt:    #FDF3E3;
  --red:         #B83232;
  --red-lt:      #FDEAEA;
  --teal:        #0D8A7A;
  --teal-lt:     #E5F6F4;

  --font: 'DM Sans', sans-serif;
  --font-serif: 'DM Serif Display', serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 14px; scroll-behavior: smooth; }

body {
  font-family: var(--font);
  background: #1A2438;
  color: var(--navy);
  line-height: 1.5;
}

/* ═══════════════════════════════════════════════════════
   NAVIGATION RAIL
═══════════════════════════════════════════════════════ */
.nav {
  position: fixed;
  left: 0; top: 0; bottom: 0;
  width: 52px;
  background: var(--navy);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
  gap: 4px;
  border-right: 1px solid rgba(186,202,236,0.08);
}

.nav-logo {
  font-size: 11px;
  font-weight: 700;
  color: var(--blue);
  letter-spacing: 0.1em;
  writing-mode: vertical-lr;
  transform: rotate(180deg);
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(186,202,236,0.15);
  width: 100%;
  text-align: center;
}

.nav-item {
  width: 36px; height: 36px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 700;
  color: var(--muted);
  cursor: pointer;
  transition: all 0.15s;
  text-decoration: none;
  letter-spacing: 0.04em;
  border: 1px solid transparent;
}

.nav-item:hover { background: rgba(15,117,189,0.15); color: var(--light-blue); border-color: rgba(15,117,189,0.2); }
.nav-item.active { background: var(--blue); color: var(--white); }

/* ═══════════════════════════════════════════════════════
   MAIN CONTENT
═══════════════════════════════════════════════════════ */
.main { margin-left: 52px; }

/* ═══════════════════════════════════════════════════════
   SLIDE WRAPPER
═══════════════════════════════════════════════════════ */
.slide {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  border-bottom: 3px solid var(--navy);
  scroll-margin-top: 0;
}

/* ═══════════════════════════════════════════════════════
   SHARED COMPONENTS
═══════════════════════════════════════════════════════ */

/* Slide header */
.slide-header {
  background: var(--white);
  padding: 20px 36px 16px;
  border-bottom: 2px solid var(--border);
  position: relative;
}

.slide-header::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4px;
  background: var(--blue);
}

.slide-num {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--blue);
  text-transform: uppercase;
  margin-bottom: 4px;
  padding-left: 12px;
}

.slide-title {
  font-family: var(--font-serif);
  font-size: 28px;
  color: var(--navy);
  line-height: 1.1;
  padding-left: 12px;
  letter-spacing: -0.01em;
}

.slide-sub {
  font-size: 12.5px;
  color: var(--slate);
  font-weight: 300;
  margin-top: 4px;
  padding-left: 12px;
  font-style: italic;
}

.slide-footer {
  margin-top: auto;
  padding: 8px 36px;
  background: var(--navy);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 10px;
  color: rgba(186,202,236,0.45);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  font-weight: 500;
}

/* Section label */
.section-label {
  padding: 8px 36px;
  background: var(--bg-alt);
  border-bottom: 1px solid var(--border);
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
  display: flex;
  align-items: center;
  gap: 12px;
}
.section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

/* KPI tiles */
.kpi-grid { display: grid; padding: 20px 36px; gap: 16px; }
.kpi-grid-4 { grid-template-columns: repeat(4, 1fr); }
.kpi-grid-5 { grid-template-columns: repeat(5, 1fr); }
.kpi-grid-3 { grid-template-columns: repeat(3, 1fr); }

.kpi-tile {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 16px 20px;
  display: flex;
  align-items: stretch;
  gap: 12px;
  box-shadow: 0 1px 4px rgba(4,30,63,0.05);
  position: relative;
  overflow: hidden;
}

.kpi-accent {
  width: 4px;
  border-radius: 2px;
  flex-shrink: 0;
}

.kpi-body { flex: 1; min-width: 0; }

.kpi-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 4px;
  line-height: 1.3;
}

.kpi-value {
  font-family: var(--font-serif);
  font-size: 30px;
  color: var(--navy);
  line-height: 1;
  letter-spacing: -0.02em;
}

.kpi-desc {
  font-size: 11px;
  color: var(--slate);
  margin-top: 3px;
  font-weight: 400;
}

/* Content area */
.content { padding: 0 36px 20px; flex: 1; display: flex; flex-direction: column; gap: 20px; }
.content-row { display: grid; gap: 20px; }
.col-2 { grid-template-columns: 1fr 1fr; }
.col-2-wide { grid-template-columns: 1.6fr 1fr; }
.col-2-narrow { grid-template-columns: 1fr 1.6fr; }
.col-3 { grid-template-columns: 1fr 1fr 1fr; }

/* Card */
.card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 2px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(4,30,63,0.05);
}

.card-header {
  padding: 10px 16px 8px;
  border-bottom: 1px solid var(--border-lt);
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--blue);
  background: var(--bg-alt);
}

.card-body { padding: 16px; }

/* Table */
.data-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }

.data-table thead th {
  background: var(--navy);
  color: var(--white);
  padding: 9px 12px;
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-align: left;
  border-right: 1px solid rgba(255,255,255,0.07);
  white-space: nowrap;
}

.data-table thead th:last-child { border-right: none; }

.data-table thead th.th-center { text-align: center; }

.data-table tbody tr:nth-child(even) { background: var(--bg); }
.data-table tbody tr:nth-child(odd)  { background: var(--white); }
.data-table tbody tr:hover { background: var(--blue-xlt); }

.data-table tbody td {
  padding: 8px 12px;
  border-bottom: 1px solid var(--border-lt);
  border-right: 1px solid var(--border-lt);
  font-variant-numeric: tabular-nums;
  vertical-align: middle;
}

.data-table tbody td:last-child { border-right: none; }

.td-bold { font-weight: 700; color: var(--navy); }
.td-blue { color: var(--blue); font-weight: 600; }
.td-indigo { color: var(--indigo); font-weight: 500; }
.td-muted { color: var(--muted); }
.td-green { color: var(--green); font-weight: 600; }
.td-amber { color: var(--amber); font-weight: 600; }
.td-red { color: var(--red); }
.td-center { text-align: center; }
.td-right  { text-align: right; }

/* Horizontal bar */
.hbar-wrap { display: flex; align-items: center; gap: 10px; }
.hbar-label { font-size: 12px; color: var(--slate); min-width: 180px; }
.hbar-track { flex: 1; height: 8px; background: var(--border-lt); border-radius: 2px; overflow: hidden; }
.hbar-fill { height: 100%; border-radius: 2px; transition: width 0.6s ease; }
.hbar-pct { font-size: 12px; font-weight: 700; color: var(--navy); min-width: 36px; text-align: right; }

/* Tier badge */
.tier-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px; height: 24px;
  border-radius: 2px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.05em;
}
.tier-a { background: var(--blue); color: var(--white); }
.tier-b { background: var(--indigo); color: var(--white); }
.tier-c { background: var(--light-blue); color: var(--navy); }

/* Priority badge */
.priority-a { color: var(--blue); font-weight: 800; font-size: 13px; }
.priority-b { color: var(--indigo); font-weight: 700; font-size: 13px; }
.priority-c { color: var(--muted); font-weight: 600; font-size: 13px; }

/* Dot rating */
.dots { letter-spacing: -1px; font-size: 13px; }

/* Pct mini bar in cell */
.pct-cell { display: flex; align-items: center; gap: 6px; }
.pct-mini-track { width: 44px; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; flex-shrink: 0; }
.pct-mini-fill { height: 100%; border-radius: 2px; }
.pct-val { min-width: 40px; text-align: right; font-size: 12px; font-variant-numeric: tabular-nums; }

/* Archetype card */
.archetype-card {
  border-radius: 2px;
  overflow: hidden;
  border: 1px solid var(--border);
}
.archetype-top {
  padding: 12px 16px 8px;
  border-bottom: 1px solid var(--border-lt);
}
.archetype-name { font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 2px; }
.archetype-pct { font-family: var(--font-serif); font-size: 22px; color: var(--blue); line-height: 1; }
.archetype-body { padding: 12px 16px; font-size: 11.5px; color: var(--slate); line-height: 1.5; }
.archetype-tag { font-size: 11px; font-style: italic; color: var(--blue); margin-top: 6px; }

/* Stat pill row */
.stat-pills { display: flex; gap: 8px; flex-wrap: wrap; }
.stat-pill {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 8px 12px;
  font-size: 11.5px;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80px;
  flex: 1;
}
.stat-pill-val { font-weight: 700; font-size: 15px; color: var(--navy); }
.stat-pill-lbl { font-size: 10px; color: var(--muted); margin-top: 2px; text-align: center; }

/* Info card (score definitions) */
.info-card {
  border-radius: 2px;
  overflow: hidden;
  border-left: 3px solid var(--border);
}
.info-card.blue  { border-left-color: var(--blue); background: var(--blue-xlt); }
.info-card.indigo { border-left-color: var(--indigo); background: var(--indigo-lt); }
.info-card.teal  { border-left-color: var(--teal); background: var(--teal-lt); }
.info-card.navy  { border-left-color: var(--navy); background: var(--bg); }
.info-card-header { padding: 8px 12px 4px; font-weight: 700; font-size: 12.5px; color: var(--navy); }
.info-card-body { padding: 4px 12px 10px; font-size: 11.5px; color: var(--slate); }
.info-card-fields { padding: 0 12px 8px; font-size: 10.5px; font-style: italic; color: var(--blue); }

/* Signal card */
.signal-card {
  border-radius: 2px;
  border: 1px solid var(--border);
  overflow: hidden;
}
.signal-top { height: 4px; }
.signal-body { padding: 12px 16px; }
.signal-title { font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
.signal-desc { font-size: 11.5px; color: var(--slate); line-height: 1.5; }

/* ═══════════════════════════════════════════════════════
   SLIDE 1 - COVER
═══════════════════════════════════════════════════════ */
#s1 {
  background: var(--navy);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

#s1::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 5px;
  background: var(--blue);
}

#s1::after {
  content: '';
  position: absolute;
  right: -120px; top: -120px;
  width: 480px; height: 480px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(15,117,189,0.08) 0%, transparent 65%);
  pointer-events: none;
}

.cover-body {
  flex: 1;
  display: flex;
  align-items: flex-start;
  padding: 60px 60px 40px 60px;
  gap: 60px;
}

.cover-left { flex: 1; padding-top: 20px; }

.cover-eyebrow {
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.2em;
  color: var(--blue);
  text-transform: uppercase;
  margin-bottom: 18px;
}

.cover-title {
  font-family: var(--font-serif);
  font-size: 58px;
  color: var(--white);
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 28px;
}

.cover-title span { color: var(--light-blue); font-style: italic; }

.cover-tagline {
  font-size: 13px;
  color: var(--muted);
  font-weight: 300;
  line-height: 1.7;
  max-width: 520px;
  border-left: 2px solid rgba(15,117,189,0.4);
  padding-left: 16px;
}

.cover-right {
  width: 260px;
  flex-shrink: 0;
  padding-top: 20px;
}

.cover-toc-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 14px;
}

.cover-toc-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 10px;
  border-radius: 2px;
  font-size: 12px;
  color: rgba(186,202,236,0.55);
  cursor: pointer;
  text-decoration: none;
  transition: all 0.15s;
  border-left: 2px solid transparent;
}

.cover-toc-item:hover { color: var(--light-blue); background: rgba(15,117,189,0.08); border-left-color: var(--blue); }

.cover-toc-item.active { color: var(--white); border-left-color: var(--blue); background: rgba(15,117,189,0.12); }

.cover-toc-num { font-size: 9.5px; font-weight: 700; color: var(--blue); min-width: 18px; }

.cover-footer {
  padding: 16px 60px;
  border-top: 1px solid rgba(186,202,236,0.1);
  display: flex;
  gap: 0;
}

.cover-meta {
  flex: 1;
  padding: 10px 24px 10px 0;
  border-right: 1px solid rgba(186,202,236,0.1);
  font-size: 11px;
  font-weight: 600;
  color: var(--blue);
  letter-spacing: 0.08em;
}

.cover-meta:last-child { border-right: none; padding-left: 24px; }

.cover-meta span { display: block; font-size: 9px; color: var(--muted); font-weight: 400; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 3px; }

/* ═══════════════════════════════════════════════════════
   DONUT CHART (CSS only)
═══════════════════════════════════════════════════════ */
.donut-wrap { display: flex; align-items: center; gap: 24px; }

.donut {
  width: 130px; height: 130px;
  border-radius: 50%;
  flex-shrink: 0;
  background: conic-gradient(
    var(--teal) 0deg 266deg,
    var(--indigo) 266deg 331deg,
    var(--blue) 331deg 360deg
  );
  position: relative;
}

.donut::after {
  content: '';
  position: absolute;
  inset: 28px;
  border-radius: 50%;
  background: var(--white);
}

.donut-legend { display: flex; flex-direction: column; gap: 6px; }
.donut-legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; }
.donut-legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
.donut-legend-pct { font-weight: 700; color: var(--navy); min-width: 32px; }
.donut-legend-lbl { color: var(--slate); }

/* Rating bar */
.rating-bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.rating-label { font-size: 12px; color: var(--slate); min-width: 110px; }
.rating-track { flex: 1; height: 14px; background: var(--border-lt); border-radius: 2px; overflow: hidden; }
.rating-fill { height: 100%; border-radius: 2px; }
.rating-pct { font-size: 12px; font-weight: 700; color: var(--navy); min-width: 32px; text-align: right; }

/* Outreach tier rows */
.outreach-tier {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1.4fr auto;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--border-lt);
}
.outreach-tier:last-child { border-bottom: none; }
.outreach-tier:nth-child(even) { background: var(--bg); }

.ot-name { font-weight: 700; font-size: 12.5px; color: var(--navy); }
.ot-sub { font-size: 11px; color: var(--muted); }
.ot-records { font-size: 12px; color: var(--slate); }
.ot-contacts { font-size: 12px; color: var(--blue); }
.ot-badge {
  padding: 3px 8px;
  border-radius: 2px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  white-space: nowrap;
  text-align: center;
}
.ot-badge.ready { background: var(--green-lt); color: var(--green); }
.ot-badge.partial { background: var(--amber-lt); color: var(--amber); }
.ot-badge.low { background: var(--bg-alt); color: var(--muted); }

/* PE heat row */
.pe-heat-row {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr 1fr;
  align-items: center;
  gap: 12px;
  padding: 8px 12px;
  border-bottom: 1px solid var(--border-lt);
}
.pe-heat-row:nth-child(even) { background: var(--bg); }
.pe-heat-row:last-child { border-bottom: none; }
.pe-region { font-size: 12.5px; color: var(--slate); }
.pe-label-hot  { font-weight: 700; color: var(--red); font-size: 12px; }
.pe-label-warm { font-weight: 700; color: var(--amber); font-size: 12px; }
.pe-label-cool { font-weight: 600; color: var(--teal); font-size: 12px; }
.pe-label-min  { color: var(--green); font-weight: 600; font-size: 12px; }

/* State table specifics */
.td-state-row { font-weight: 700; font-size: 12px; color: var(--navy); letter-spacing: 0.06em; }
.td-pct-hot  { color: var(--blue); font-weight: 700; }
.td-pct-warm { color: var(--blue-dark); font-weight: 600; }
.td-pct-cool { color: var(--muted); }

</style>
</head>
<body>

<!-- ══ NAVIGATION RAIL ══════════════════════════════════ -->
<nav class="nav">
  <div class="nav-logo">STOC</div>
  <a href="#s1"  class="nav-item active" title="Cover">CV</a>
  <a href="#s2"  class="nav-item" title="Market Overview">01</a>
  <a href="#s3"  class="nav-item" title="Top Target Markets">02</a>
  <a href="#s4"  class="nav-item" title="Quality &amp; Maturity">03</a>
  <a href="#s5"  class="nav-item" title="Geographic Opportunity">04</a>
  <a href="#s6"  class="nav-item" title="Competitive Landscape">05</a>
  <a href="#s7"  class="nav-item" title="Opportunity Profile">06</a>
  <a href="#s8"  class="nav-item" title="PE Consolidation">07</a>
  <a href="#s9"  class="nav-item" title="By State Summary">08</a>
  <a href="#s10" class="nav-item" title="Appendix">AP</a>
</nav>

<div class="main">

<!-- ══════════════════════════════════════════════════════
  SLIDE 1 - COVER
══════════════════════════════════════════════════════ -->
<section id="s1" class="slide">
  <div class="cover-body">
    <div class="cover-left">
      <div class="cover-eyebrow">Sector Intelligence Report &nbsp;·&nbsp; MedSpa &nbsp;·&nbsp; Sector 01 of 03</div>
      <div class="cover-title">MedSpa<br>Market<br><span>Intelligence</span><br>Report</div>
      <div class="cover-tagline">
        Fragmentation Analysis &nbsp;·&nbsp; Geographic Opportunity &nbsp;·&nbsp; PE Consolidation Activity &nbsp;·&nbsp; Operator Quality Benchmarks &nbsp;·&nbsp; Outreach Readiness
      </div>
    </div>
    <div class="cover-right">
      <div class="cover-toc-label">Contents</div>
